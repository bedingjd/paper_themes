	<TextSource modifyingUser="F3EA8DA1-BB99-411F-8ED4-011170237B6C" guid="1FF22868-3407-46BC-8189-6DD9E70B0885" creatingUser="F3EA8DA1-BB99-411F-8ED4-011170237B6C" creationDateTime="2024-10-18T23:23:58Z" name="ICLS 2024 35-42" plainTextPath="internal://1FF22868-3407-46BC-8189-6DD9E70B0885.txt" modifiedDateTime="2024-10-18T23:23:58Z"/>
	<TextSource modifyingUser="F3EA8DA1-BB99-411F-8ED4-011170237B6C" guid="1C693BD8-FFE2-4398-AB33-0831971751F4" creatingUser="F3EA8DA1-BB99-411F-8ED4-011170237B6C" creationDateTime="2025-06-16T22:00:02Z" name="ICLS 2025 1007-1015" plainTextPath="internal://1C693BD8-FFE2-4398-AB33-0831971751F4.txt" modifiedDateTime="2025-06-16T22:00:02Z"/>
	<TextSource modifyingUser="F3EA8DA1-BB99-411F-8ED4-011170237B6C" guid="EB84B1CD-7263-4AD1-82D3-B229B7EE734A" creatingUser="F3EA8DA1-BB99-411F-8ED4-011170237B6C" creationDateTime="2025-06-16T22:00:04Z" name="ICLS 2025 101-109" plainTextPath="internal://EB84B1CD-7263-4AD1-82D3-B229B7EE734A.txt" modifiedDateTime="2025-06-16T22:00:04Z"/>
	<TextSource modifyingUser="F3EA8DA1-BB99-411F-8ED4-011170237B6C" guid="B787D8CD-082E-401C-B13B-82225ED71363" creatingUser="F3EA8DA1-BB99-411F-8ED4-011170237B6C" creationDateTime="2025-06-16T22:00:12Z" name="ICLS 2025 1016-1024" plainTextPath="internal://B787D8CD-082E-401C-B13B-82225ED71363.txt" modifiedDateTime="2025-06-16T22:00:12Z"/>
	<TextSource modifyingUser="F3EA8DA1-BB99-411F-8ED4-011170237B6C" guid="3CEF20B2-0549-42C3-9B05-796FA9EBF763" creatingUser="F3EA8DA1-BB99-411F-8ED4-011170237B6C" creationDateTime="2025-06-16T22:00:14Z" name="ICLS 2025 1025-1033" plainTextPath="internal://3CEF20B2-0549-42C3-9B05-796FA9EBF763.txt" modifiedDateTime="2025-06-16T22:00:14Z"/>
	<TextSource modifyingUser="F3EA8DA1-BB99-411F-8ED4-011170237B6C" guid="DFBA1BB6-2213-427B-819D-35408645187D" creatingUser="F3EA8DA1-BB99-411F-8ED4-011170237B6C" creationDateTime="2025-06-16T22:00:15Z" name="ICLS 2025 1034-1042" plainTextPath="internal://DFBA1BB6-2213-427B-819D-35408645187D.txt" modifiedDateTime="2025-06-16T22:00:15Z"/>
